<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <link rel="stylesheet" href="~/css/main.css" />
    <link rel="stylesheet" href="~/css/responsive.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>@ViewData["Title"] - SICOVWEB_MCA</title>
    @* <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/> *@
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" /> <!-- Llama libreria de mensajes alert TOASTR-->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"> <!-- Libreria de iconos -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous"> <!-- CDN Bootstrap 5-->
</head>

<body>
   
    <div class="container">
        
        <main role="main" class="pb-3">
            
            @RenderBody()
        </main>
    </div>
   <!-- Pie de página index -->
    <footer >
        <div class="container" style="color: #17202a ; font-size: 1.2rem ">
            &copy; 2025 - SICOVWEB_MCA -
            
            <a asp-area="" class="btn-secundario" asp-controller="Home" asp-action="Contacto"><i class="bi bi-telephone"></i> Contactanos</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- Se usa para consumir la vista parcial de Notificaciones alert -->
    <partial name="_Notificacion" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
