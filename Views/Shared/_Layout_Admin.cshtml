<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="~/css/main.css" />
    <link rel="stylesheet" href="~/css/responsive.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>    
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" /> <!-- Llama libreria de mensajes alert TOASTR-->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"> <!-- Libreria de iconos -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous"> <!-- CDN Bootstrap 5-->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>


<body>
    <button class="btn-menu-mobile" id="btnMenu">
        ☰ Menú
    </button>
    <div class="sidebar">        
        <img src="~/images/logo_empresa.png" width="250" height="200" >
        <!-- Menú lateral-->
        <h2>Menú</h2>
        <a asp-area="" asp-controller="Login_Controlador" asp-action="VolverInicio">Inicio</a>
        <a asp-area="" asp-controller="Cotizaciones" asp-action="Consultar">Cotizaciones</a>
        <a asp-area="" asp-controller="CotizacionesProveedores" asp-action="Buscar">Cotizaciones Proveedores</a>
        <a asp-area="" asp-controller="Usuarios" asp-action="Buscar">Usuarios</a>
        <a asp-area="" asp-controller="Empleados" asp-action="Buscar">Empleados</a>
        <a asp-area="" asp-controller="Clientes" asp-action="Buscar">Clientes</a>
        <a asp-area="" asp-controller="Proveedores" asp-action="ListaProveedores">Proveedores</a>
        <a asp-area="" asp-controller="Productos" asp-action="ListaProductos">Productos</a>
        <a asp-area="" asp-controller="Promociones" asp-action="ListaPromociones">Promociones</a>
        <a asp-area="" asp-controller="Ventas" asp-action="ListaVentas">Ventas</a>
               
        <!--Cerrar sesión-->
        <a asp-area="" asp-controller="Login_Controlador" asp-action="Logout">Cerrar sesión</a>
        <!-- Se usa para consumir la vista parcial de Notificaciones alert -->
        <partial name="_Notificacion" />
        @RenderSection("Sidebar", required: false)
    </div>
    
    
    @* Contenido de la pagina  *@
    <div class="content">
        <div>
            @* <img src="~/images/LOGO_SICOVWEB_CIRCULO.png" id="LogoHeader" /> *@
            <!-- Nombre del usuario con sesión iniciada -->
            <h3 id="UsuarioLogueado" style="align-items: end;"><i class="bi bi-person-vcard-fill"></i> @User.Identity.Name</h3>
            
        </div>

        @RenderBody()

        <!-- Footer -->
        <footer>
            <div class="container">
                &copy; 2025 - SICOVWEB-MCA
                <a asp-area="" class="btn-primario" asp-controller="Home" asp-action="Contacto"><i class="bi bi-telephone"> Contacto</i></a>
            </div>
        </footer>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
   
    @* <script src="~/js/menuMobile.js"></script> *@
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const btnMenu = document.querySelector(".btn-menu-mobile");
            const sidebar = document.querySelector(".sidebar");
            const overlay = document.createElement("div");

            // Crear el overlay dinámicamente si no existe
            overlay.classList.add("overlay-menu");
            document.body.appendChild(overlay);

            if (btnMenu && sidebar) {
                btnMenu.addEventListener("click", () => {
                    sidebar.classList.toggle("activa");
                    overlay.classList.toggle("activa");
                });

                // Cerrar menú al hacer clic fuera
                overlay.addEventListener("click", () => {
                    sidebar.classList.remove("activa");
                    overlay.classList.remove("activa");
                });
            }
        });
    </script>
    <script>
        window.addEventListener("pageshow", function (evt) {
            if (evt.persisted) {
                window.location.reload();
            }
        });
    </script>

</body>

</html>



